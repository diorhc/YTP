{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "youtubeplus",
  "version": "2.5.1",
  "description": "Professional-grade YouTube enhancement userscript with modular architecture, comprehensive error handling, performance monitoring, and automated testing",
  "private": true,
  "author": "diorhc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diorhc/YTP.git"
  },
  "bugs": {
    "url": "https://github.com/diorhc/YTP/issues"
  },
  "homepage": "https://github.com/diorhc/YTP#readme",
  "keywords": [
    "userscript",
    "youtube",
    "greasemonkey",
    "tampermonkey",
    "browser-extension",
    "video-enhancement",
    "modular-architecture"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "prepare": "husky install",
    "build": "node build.js",
    "build:watch": "node build.js --watch",
    "build:production": "node build.js --optimized",
    "build:translations": "node build.js --optimized && node embed-translations.js",
    "lint": "eslint --no-warn-ignored \"src/**/*.js\" \"build.js\"",
    "lint:fix": "eslint --no-warn-ignored \"src/**/*.js\" \"build.js\" --fix",
    "knip": "knip --config knip.json",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.js\" \"*.js\" \"!youtube.user.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"*.js\" \"!youtube.user.js\"",
    "test": "npm run lint && npm run format:check && npm run test:unit && npm run build",
    "test:unit": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "npx playwright test",
    "security": "npm audit --audit-level=high --omit=dev && node scripts/security-innerhtml-scan.js && npm run lint",
    "precommit": "lint-staged",
    "prepush": "npm run typecheck && npm run security && npm run test:unit",
    "validate": "npm run typecheck && npm run lint && npm run test:unit",
    "validate:design-system": "node scripts/validate-design-system.js",
    "analyze": "node scripts/analyze.js",
    "analyze:dom-cache": "node scripts/audit-dom-cache.js",
    "clean": "node -e \"require('fs').rmSync('coverage', {recursive: true, force: true}); require('fs').rmSync('youtube.user.js', {force: true}); require('fs').rmSync('youtube.user.js.map', {force: true}); require('fs').rmSync('bundle-size-report.json', {force: true}); require('fs').rmSync('eslint-report.json', {force: true});\" && echo Cleaned build artifacts",
    "ci": "npm run typecheck && npm run lint && npm run knip && npm run test:coverage && npm run build:production && node scripts/check-modules.js && node scripts/analyze.js size --fail-on-error",
    "update:badges": "node scripts/update-greasyfork-badges.js https://greasyfork.org/ru/scripts/537017-youtube README.md"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@playwright/test": "^1.60.0",
    "@size-limit/file": "^12.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.12.3",
    "chokidar": "^4.0.3",
    "cloakbrowser": "^0.3.30",
    "eslint": "^9.39.4",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "knip": "^6.14.1",
    "lint-staged": "^17.0.4",
    "playwright": "^1.60.0",
    "playwright-extra": "^4.3.6",
    "prettier": "^3.8.3",
    "puppeteer": "^24.43.0",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "size-limit": "^12.1.0",
    "stylelint-config-standard": "^40.0.0",
    "terser": "^5.47.1",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "ws": "^8.20.1",
    "yauzl": "^3.2.1"
  },
  "lint-staged": {
    "src/**/*.js": [
      "eslint --no-warn-ignored --fix",
      "prettier --write"
    ],
    "build.js": [
      "eslint --no-warn-ignored --fix",
      "prettier --write"
    ]
  }
}
