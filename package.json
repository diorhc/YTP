{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "youtubeplus",
  "version": "2.5.2",
  "description": "Professional-grade YouTube enhancement userscript with modular architecture, comprehensive error handling, performance monitoring, and automated testing",
  "private": true,
  "author": "diorhc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/diorhc/YTP.git"
  },
  "bugs": {
    "url": "https://github.com/diorhc/YTP/issues"
  },
  "homepage": "https://github.com/diorhc/YTP#readme",
  "keywords": [
    "userscript",
    "youtube",
    "greasemonkey",
    "tampermonkey",
    "browser-extension",
    "video-enhancement",
    "modular-architecture"
  ],
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "prepare": "husky install",
    "build": "node build.js",
    "build:watch": "node build.js --watch",
    "build:production": "node build.js --optimized",
    "build:optimized": "npm run build:production",
    "build:minify": "node build.js --minify",
    "build:translations": "node build.js --optimized && node embed-translations.js",
    "build:dry-run": "node build.js --dry-run",
    "lint": "biome check --no-errors-on-unmatched \"src\" \"build.js\"",
    "lint:fix": "biome check --write --no-errors-on-unmatched \"src\" \"build.js\"",
    "lint:csp": "node scripts/security-innerhtml-scan.js",
    "lint:custom": "node scripts/lint-custom-rules.js",
    "knip": "knip --config knip.json",
    "knip:strict": "npm run knip",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write --no-errors-on-unmatched \"src\" \"build.js\"",
    "format:check": "biome format --no-errors-on-unmatched \"src\" \"build.js\"",
    "test": "npm run lint && npm run test:unit && npm run build",
    "test:unit": "jest",
    "test:ci": "npm run test:coverage",
    "test:coverage": "jest --coverage",
    "test:real": "node scripts/test-real.mjs",
    "test:e2e": "npx playwright test",
    "security": "npm audit --audit-level=high --omit=dev && npm run lint:csp && npm run lint",
    "security:full": "npm run security && npm run validate",
    "precommit": "lint-staged",
    "prepush": "npm run typecheck && npm run security && npm run test:unit",
    "validate": "npm run typecheck && npm run lint && npm run test:unit",
    "validate:design-system": "node scripts/validate-design-system.js",
    "audit:i18n": "node scripts/audit-i18n.js",
    "analyze": "node scripts/analyze.js",
    "analyze:dom-cache": "node scripts/audit-dom-cache.js",
    "clean": "node -e \"require('fs').rmSync('coverage', {recursive: true, force: true}); require('fs').rmSync('youtube.user.js', {force: true}); require('fs').rmSync('youtube.user.js.map', {force: true}); require('fs').rmSync('bundle-size-report.json', {force: true});\" && echo Cleaned build artifacts",
    "ci": "npm run typecheck && npm run lint && npm run format:check && npm run knip && npm run test:coverage && npm run build:production && node scripts/check-modules.js && node scripts/analyze.js size --fail-on-error",
    "size:check": "node scripts/analyze.js size --fail-on-error",
    "update:badges": "node scripts/update-greasyfork-badges.js https://greasyfork.org/ru/scripts/537017-youtube README.md",
    "docs:gen": "npx typedoc"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@jest/globals": "^30.4.1",
    "@playwright/test": "^1.61.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.0.1",
    "chokidar": "^5.0.0",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "knip": "^6.23.0",
    "lint-staged": "^17.0.8",
    "playwright": "^1.61.1",
    "terser": "^5.48.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "ws": "^8.20.1",
    "yauzl": "^3.2.1"
  },
  "lint-staged": {
    "src/**/*.js": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "build.js": [
      "biome check --write --no-errors-on-unmatched"
    ]
  }
}
