    "src/enhanced.js",
    "src/adblocker.js",
    "src/pip.js",
    "src/timecode.js",
    "src/playlist-search.js",
    "src/thumbnail.js",
    "src/shorts.js",
    "src/stats.js",
    "src/comment.js",
    "src/report.js",
    "src/update.js",
    "src/music.js",
